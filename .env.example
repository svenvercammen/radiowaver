# Kopieer dit bestand naar .env en vul echte waarden in.
#   cp .env.example .env
# .env staat in .gitignore en mag NOOIT gecommit worden.

# Bronwachtwoord — zet exact dezelfde waarde in BUTT (Settings -> Main).
ICECAST_SOURCE_PASSWORD=verander-mij-source

# Relay-wachtwoord (niet gebruikt voor dit project, maar Icecast vereist een waarde).
ICECAST_RELAY_PASSWORD=verander-mij-relay

# Admin-wachtwoord voor de Icecast admin-interface (:8000/admin, niet publiek).
ICECAST_ADMIN_PASSWORD=verander-mij-admin

# Hostname die Icecast in stream-URLs gebruikt.
#   productie: radio.waver.be
#   lokaal dev: localhost
ICECAST_HOSTNAME=radio.waver.be
