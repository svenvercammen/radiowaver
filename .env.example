# Kopieer dit bestand naar .env en vul echte waarden in.
#   cp .env.example .env
# .env staat in .gitignore en mag NOOIT gecommit worden.

# ---------------------------------------------------------------------------
# Icecast (streaming)
# ---------------------------------------------------------------------------
# Bronwachtwoord — zet exact dezelfde waarde in BUTT (Settings -> Main).
ICECAST_SOURCE_PASSWORD=verander-mij-source
# Relay-wachtwoord (niet gebruikt, maar Icecast vereist een waarde).
ICECAST_RELAY_PASSWORD=verander-mij-relay
# Admin-wachtwoord voor de Icecast admin-interface (:8000/admin, niet publiek).
ICECAST_ADMIN_PASSWORD=verander-mij-admin
# Hostname die Icecast in stream-URLs gebruikt (productie: radio.waver.be).
ICECAST_HOSTNAME=radio.waver.be

# ---------------------------------------------------------------------------
# Beheer-API (FastAPI) — Keycloak-validatie
# ---------------------------------------------------------------------------
# Publieke issuer = wat in de tokens staat (moet matchen met PUBLIC_URL + /auth).
KEYCLOAK_ISSUER=https://radio.waver.be/auth/realms/radiowaver
# Interne issuer = waar de API de JWKS ophaalt (containernaam, geen TLS nodig).
KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8080/auth/realms/radiowaver
# Realm-rol die beheer mag doen.
KEYCLOAK_ADMIN_ROLE=beheerder

# ---------------------------------------------------------------------------
# Keycloak (eigen container)
# ---------------------------------------------------------------------------
# Publieke basis-URL van de site (stuurt Keycloak-hostname).
PUBLIC_URL=https://radio.waver.be
# Bootstrap-admin van Keycloak (de master-admin console, /auth/admin).
KC_ADMIN=admin
KC_ADMIN_PASSWORD=verander-mij-kc-admin
