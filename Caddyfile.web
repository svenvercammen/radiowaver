# Interne Caddy van de radiowaver-web container (productie). Luistert op :80
# binnen Docker; de gedeelde Caddy ervoor termineert TLS en proxyt
# radio.waver.be hierheen. Daarom hier geen automatische HTTPS.
{
	auto_https off
}

:80 {
	# Live stream + status van Icecast (same-origin, low-latency).
	@icecast path /live /status-json.xsl
	handle @icecast {
		reverse_proxy icecast:8000 {
			flush_interval -1
		}
	}

	# Beheer-API.
	handle /api/* {
		reverse_proxy api:8000
	}

	# Keycloak (login voor het beheer), onder /auth.
	# De gedeelde Caddy ervoor termineert TLS; forceer hier https zodat
	# Keycloak correcte (https) redirect-/issuer-URLs opbouwt.
	handle /auth/* {
		reverse_proxy keycloak:8080 {
			header_up X-Forwarded-Proto https
		}
	}

	# Geüploade logo's en affiches.
	handle_path /uploads/* {
		root * /srv/data/uploads
		file_server
	}

	# Statische pagina's: publieke speler (/) en beheerpagina (/beheer/).
	handle {
		root * /srv/web
		file_server
	}
}
