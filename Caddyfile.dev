# Lokale dev-Caddy (geen TLS). Bootst de productie-routing na op poort 8080.
{
	auto_https off
}

:8080 {
	@icecast path /live /status-json.xsl
	handle @icecast {
		reverse_proxy icecast:8000 {
			flush_interval -1
		}
	}

	handle /api/* {
		reverse_proxy api:8000
	}

	handle /auth/* {
		reverse_proxy keycloak:8080
	}

	handle_path /uploads/* {
		root * /srv/data/uploads
		file_server
	}

	handle {
		root * /srv/web
		file_server
	}
}
